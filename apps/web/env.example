# Ambiente de desenvolvimento ou produção
NODE_ENV=development # development ou production

# URL interna da API (apps/api). Em Docker usa o nome do serviço. Em dev local: http://localhost:3001
API_URL=http://localhost:3001

# URL pública da API usada pelo browser para websocket realtime.
NEXT_PUBLIC_API_ORIGIN=http://localhost:3001

# Caminho base da aplicação, sem barra final, podendo ser: /silo ou apenas /
NEXT_PUBLIC_BASE_PATH=/silo

# URL da aplicação, sem subdiretório. A definição de subdiretório base é feita no NEXT_PUBLIC_BASE_PATH.
APP_URL_DEV=http://localhost:3000
APP_URL_PROD=https://fortuna.cptec.inpe.br

# Kafka REST Proxy (fonte das telas /admin/monitoring e /admin/products/:slug/data-flow)
KAFKA_REST_PROXY_URL=http://localhost:8082
KAFKA_REST_PROXY_AUTH=
# Enquanto o REST Proxy real nao estiver disponivel, manter true para usar os dados fake existentes.
KAFKA_REST_PROXY_USE_MOCK_DATA=true
KAFKA_DATAFLOW_TOPIC_PREFIX=silo.dataflow.
KAFKA_GROUP_ID=silo-consumer-group
# Tópico único para rodar 1 consumidor por tópico, ou lista CSV em KAFKA_TOPICS.
KAFKA_TOPIC=
KAFKA_TOPICS=
KAFKA_DLQ_PREFIX=dlq.
KAFKA_PROCESS_RETRY_COUNT=3
KAFKA_RETRY_BACKOFF_MS=1000

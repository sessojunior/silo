{
  "name": "silo",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "api:smoke": "node scripts/api-smoke.mjs",
    "web:visual": "node scripts/web-visual-smoke.mjs",
    "web:visual:inventory": "node scripts/web-visual-smoke.mjs --inventory",
    "format": "prettier --write .",
    "db:generate": "turbo run db:generate --filter=@silo/database",
    "db:push": "turbo run db:push --filter=@silo/database",
    "db:migrate": "turbo run db:migrate --filter=@silo/database",
    "db:studio": "turbo run db:studio --filter=@silo/database",
    "deploy": "node deploy.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "prettier": "^3.8.1",
    "turbo": "^2.5.4",
    "typescript": "^5.9.3"
  }
}

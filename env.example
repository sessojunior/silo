# Ambiente de desenvolvimento ou produção
NODE_ENV=development # development ou production

# URL interna da API usada pelos proxies do web em chamadas server-side.
API_URL=http://localhost:3001

# URL pública da API usada pelo browser para websocket realtime.
NEXT_PUBLIC_API_ORIGIN=http://localhost:3001

# URL do banco de dados PostgreSQL
# postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL_DEV=postgresql://usuario:senha@localhost:5432/silo

# Postgres via Docker Compose
# Use quando for subir um PostgreSQL junto com a aplicação via docker-compose.yml.
DATABASE_URL_PROD=postgresql://silo:silo@db:5432/silo
POSTGRES_DB=silo
POSTGRES_USER=silo
POSTGRES_PASSWORD=silo
POSTGRES_PORT=5432

# Dados para envio de e-mails
# 1. Ativar verificação em duas etapas (2FA) em https://myaccount.google.com/security
# 2. Criar uma senha de app (App Password) em https://myaccount.google.com/apppasswords
# 3. Copiar a senha de app de 16 caracteres, tipo essa: xxxx xxxx xxxx xxxx
SMTP_HOST=smtp.gmail.com # Exemplo: smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME= # E-mail do remetente
SMTP_PASSWORD= # Senha de app

# Autenticação com Google
# https://arcticjs.dev/providers/google
# 1. Para produção, ir em APIs e serviços: https://console.cloud.google.com/apis/dashboard
# 2. Clicar em Tela de permissão OAuth. Clique em Branding e adicione o domínio autorizado e o e-mail.
# 3. Em público-alvo, clique no botão de Publicar app e confirme. O App precisa estar com o status "Em produção" e não "Testando".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gerar o secret com um destes: `npx @better-auth/cli secret` ou `openssl rand -base64 32`
BETTER_AUTH_SECRET=your_secret_key_here

# Caminho base da aplicação, sem barra final, podendo ser: /silo ou apenas /
NEXT_PUBLIC_BASE_PATH=/silo

# URL da aplicação, sem subdiretório. A definição de subdiretório base é feita no NEXT_PUBLIC_BASE_PATH.
APP_URL_DEV=http://localhost:3000
APP_URL_PROD=https://fortuna.cptec.inpe.br

# Kafka REST Proxy (fonte das telas /admin/monitoring e /admin/products/:slug/data-flow)
KAFKA_REST_PROXY_URL=http://localhost:8082
KAFKA_REST_PROXY_AUTH=
# Enquanto o REST Proxy real nao estiver disponivel, manter true para usar os dados fake existentes.
KAFKA_REST_PROXY_USE_MOCK_DATA=true
KAFKA_DATAFLOW_TOPIC_PREFIX=silo.dataflow.
KAFKA_GROUP_ID=silo-consumer-group
# Tópico único para rodar 1 consumidor por tópico, ou lista CSV em KAFKA_TOPICS.
KAFKA_TOPIC=
KAFKA_TOPICS=
KAFKA_DLQ_PREFIX=dlq.
KAFKA_PROCESS_RETRY_COUNT=3
KAFKA_RETRY_BACKOFF_MS=1000

# Assistente de IA (Ollama + Qwen)
OLLAMA_IMAGE=ollama/ollama:0.30.0-rc7
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b-instruct-q4_K_M
OLLAMA_TIMEOUT_MS=30000
OLLAMA_MAX_CONCURRENT_REQUESTS=1
